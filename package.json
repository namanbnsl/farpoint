{
  "name": "farpoint-cli",
  "version": "0.1.2",
  "description": "Farpoint",
  "homepage": "https://github.com/namanbnsl/farpoint#readme",
  "bugs": {
    "url": "https://github.com/namanbnsl/farpoint/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namanbnsl/farpoint.git"
  },
  "bin": {
    "farpoint": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "dev": "vp pack --watch",
    "start": "node dist/cli.mjs",
    "prepack": "vp pack",
    "pack:dry": "pnpm pack --dry-run"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.10",
    "@earendil-works/pi-ai": "0.80.10",
    "ink": "7.1.1",
    "ink-big-text": "2.0.0",
    "ink-gradient": "4.0.1",
    "ink-link": "5.0.0",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "marked": "15.0.12",
    "marked-terminal": "7.3.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/marked-terminal": "6.1.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "typescript": "5.9.3",
    "vite-plus": "0.2.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
